<configs>

	<!-- ============================================================ -->
	<!-- Forge input: 2 slots to 3 slots                              -->
	<!-- 3 is an ENGINE LIMIT: TileEntityWorkstation hardcodes the    -->
	<!-- input array as 3 + materialNames.Length and starts the       -->
	<!-- material stockpile at index 3, so a 4th UI cell renders      -->
	<!-- directly over the iron stockpile slot. Vanilla only shows 2  -->
	<!-- of the engine's 3 raw slots; this surfaces the third.        -->
	<!-- ============================================================ -->

	<set xpath="/windows/window[@name='windowForgeInput']/@height">279</set>
	<set xpath="/windows/window[@name='windowForgeInput']/sprite[@name='backgroundMain']/@height">228</set>
	<set xpath="/windows/window[@name='windowForgeInput']/rect[@name='content']/@height">228</set>
	<set xpath="/windows/window[@name='windowForgeInput']/rect[@name='content']/grid/@rows">3</set>

	<!-- Stretch the material readout panel (iron/brass/lead/glass/stone/clay list) to match -->
	<set xpath="/windows/window[@name='windowForgeInput']/rect[@name='content2']/@height">223</set>
	<set xpath="/windows/window[@name='windowForgeInput']/rect[@name='content2']/grid/@cell_height">36</set>

	<!-- ============================================================ -->
	<!-- Crafting / scrapping queue: 4 slots to 10 slots (2 rows x 5) -->
	<!-- This is the queue scrapped items land in, in the backpack    -->
	<!-- and at every workstation.                                    -->
	<!-- ============================================================ -->

	<set xpath="/windows/window[@name='windowCraftingQueue']/@height">153</set>
	<set xpath="/windows/window[@name='windowCraftingQueue']/rect/@pos">19,0</set>
	<set xpath="/windows/window[@name='windowCraftingQueue']/rect/@width">378</set>
	<set xpath="/windows/window[@name='windowCraftingQueue']/rect/grid[@name='queue']/@cols">5</set>
	<set xpath="/windows/window[@name='windowCraftingQueue']/rect/grid[@name='queue']/@rows">2</set>

	<!-- ============================================================ -->
	<!-- Workstation output: 6 slots to 9 slots (3 rows x 3)          -->
	<!-- Shared by the workbench, forge, campfire, chemistry station  -->
	<!-- and cement mixer.                                            -->
	<!-- ============================================================ -->

	<set xpath="/windows/window[@name='windowOutput']/@height">276</set>
	<set xpath="/windows/window[@name='windowOutput']/rect[@name='content']/@height">228</set>
	<set xpath="/windows/window[@name='windowOutput']/rect[@name='content']/sprite[@name='backgroundMain']/@height">228</set>
	<set xpath="/windows/window[@name='windowOutput']/rect[@name='content']/grid[@name='inventory']/@rows">3</set>

</configs>
